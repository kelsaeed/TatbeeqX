# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=4040
HOST=0.0.0.0
NODE_ENV=development

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_EMAIL=superadmin@local
SEED_SUPERADMIN_PASSWORD=ChangeMe!2026

# Optional: pre-apply a business type preset on seed
# One of: retail, restaurant, clinic, factory, finance, rental, blank
# Leave empty to let the user pick from the in-app setup wizard.
SEED_BUSINESS_TYPE=

# CORS — comma-separated origins, or * for any (use only on LAN)
CORS_ORIGIN=*

# --- SMTP (Phase 4.19) ---
# Vendor-neutral. Works with any SMTP server: SendGrid relay, AWS SES
# SMTP, Postmark SMTP, Gmail (with app password), Postfix, etc.
# Leave SMTP_HOST blank to disable email entirely — the rest of the
# system still works (emails get logged in dev, no-op in prod).
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false       # true for port 465 (implicit TLS), false for 587 (STARTTLS)
# SMTP_USER=apikey-or-username
# SMTP_PASS=your-password
# SMTP_FROM="TatbeeqX <no-reply@your-domain.com>"

# Public app URL for links inside emails (password reset, etc.).
# LAN installs can leave this default; cloud installs MUST set it.
APP_URL=http://localhost:8080
