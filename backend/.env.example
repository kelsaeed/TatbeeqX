# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_EMAIL=superadmin@local
SEED_SUPERADMIN_PASSWORD=ChangeMe!2026

# Optional: pre-apply a business type preset on seed
# One of: retail, restaurant, clinic, factory, finance, rental, blank
# Leave empty to let the user pick from the in-app setup wizard.
SEED_BUSINESS_TYPE=

# CORS — comma-separated origins, or * for any (use only on LAN)
CORS_ORIGIN=*
